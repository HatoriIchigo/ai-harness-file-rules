<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <RootNamespace>ai_harness_file_rules</RootNamespace>
    <AssemblyName>ai-harness-file-rules</AssemblyName>
    <!-- NuGet 依存（TreeSitter.DotNet とネイティブ grammar）は lib/ へ同梱する必要があるため出力へコピーする。 -->
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <ItemGroup>
    <!-- baselib は host(ai-harness-main)が共有ロードするため出力にコピーしない。 -->
    <ProjectReference Include="..\..\ai-harness-baselib\ai-harness-baselib\ai-harness-baselib.csproj">
      <Private>false</Private>
    </ProjectReference>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="TreeSitter.DotNet" Version="1.3.0" />
  </ItemGroup>

  <!-- .claude/rules へ配布する rule（CopyRule）と、有効化時に無ければ置くデフォルト設定（CopyDefaultConfig）。 -->
  <ItemGroup>
    <EmbeddedResource Include="file-rules.rule.md" />
    <EmbeddedResource Include="file-rules.config.yml" />
  </ItemGroup>

</Project>
